# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Server configuration
HOST=0.0.0.0
PORT=5001

# Paths
MODEL_PATH=models/thermal_wildlife_detection/weights/best.pt
UPLOAD_FOLDER=uploads
RESULTS_FOLDER=results

# Model training configuration
EPOCHS=100
BATCH_SIZE=16
IMAGE_SIZE=640

# Thermal analysis parameters
TSI_THRESHOLD_NORMAL=0.05
TSI_THRESHOLD_MILD=0.10
TSI_THRESHOLD_MODERATE=0.15

# Temperature ranges (Celsius)
TEMP_MIN=20.0
TEMP_MAX=45.0

# Bilateral asymmetry threshold (Celsius)
ASYMMETRY_THRESHOLD=1.5

# CORS settings
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
